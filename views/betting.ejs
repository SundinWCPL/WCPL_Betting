<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Betting · WCPL Betting</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials_header') %>
  <main class="container">
    <section class="card page-title compact-title">
      <div>
        <p class="eyebrow">Week <%= bettingView.week %> · <strong class="<%= bettingView.locked ? 'negative' : 'positive' %>"><%= bettingView.locked ? 'Locked' : 'Open' %></strong></p>
        <h1>Current Week Betting Board</h1>
        <p>Mushybux: <strong><%= balanceSummary.display %></strong> <span class="muted">total (wagered)</span> · Series max: <strong><%= maxBet %></strong> · Prop max: <strong><%= propMaxBet %></strong></p>
        <% if (bettingView.locked) { %>
          <p class="negative">These bets are locked in and cannot be changed.</p>
        <% } else { %>
          <p class="muted">Change or cancel picks until weekly betting locks.</p>
        <% } %>
      </div>
      <div class="toggle-stack">
        <div class="toggle-row">
          <a class="button-link <%= betType === 'series' ? 'ghost-active' : 'ghost' %>" href="/betting?type=series">Series Bets</a>
          <a class="button-link <%= betType === 'props' ? 'ghost-active' : 'ghost' %>" href="/betting?type=props">Prop Bets</a>
        </div>
      </div>
    </section>

    <% if (betType === 'series') { %>
      <section class="board compact-board">
        <% if (!board.length) { %>
          <article class="card">
            <h2>No matchups found</h2>
            <p class="muted">No schedule rows were found for Week <%= bettingView.week %>.</p>
          </article>
        <% } %>

        <% board.forEach((s, idx) => { %>
          <article class="card series-card bet-builder compact-series" data-card-index="<%= idx %>">
            <div class="series-head compact-series-head">
              <div>
                <span class="pill"><%= s.division_name %></span>
                <h2><%= s.away_team_name %> at <%= s.home_team_name %></h2>
                <% if (s.bettingClosed) { %>
                  <p class="negative compact-no-bet">
                    Series complete · betting closed
                    <% if (s.result?.winner_team_name) { %>
                      · <%= s.result.winner_team_name %> won <%= s.result.winner_wins %>-<%= s.result.loser_wins %>
                    <% } %>
                  </p>
                <% } %>
              </div>
              <% if (s.currentBet) { %>
                <%
                  const betSettled = s.currentBet.status === 'settled';
                  const betWon = betSettled && (s.currentBet.won || Number(s.currentBet.payout || 0) > 0);
                  const betStateClass = betSettled ? (betWon ? 'bet-won' : 'bet-lost') : 'bet-pending';
                  const betStateLabel = betSettled ? (betWon ? 'Won' : 'Lost') : 'Pending';
                %>
                <div class="current-bet-box compact-current-bet <%= betStateClass %>">
                  <span class="pill"><%= betStateLabel %></span>
                  <strong><%= s.currentBet.label.split(': ').pop() %></strong>
                  <% if (betSettled) { %>
                    <span><%= s.currentBet.stake %> Mushybux · <%= s.currentBet.multiplier %>x · Payout <strong><%= Number(s.currentBet.payout || 0) %></strong></span>
                  <% } else { %>
                    <span><%= s.currentBet.stake %> Mushybux · <%= s.currentBet.multiplier %>x · Return <strong><%= Math.ceil(Number(s.currentBet.stake) * Number(s.currentBet.multiplier)) %></strong></span>
                  <% } %>
                  <% if (!betSettled && !bettingView.locked && !s.bettingClosed) { %>
                    <form method="post" action="/bets/cancel" class="cancel-bet-form" onsubmit="return confirm('Cancel this bet and return <%= s.currentBet.stake %> Mushybux?');">
                      <input type="hidden" name="view" value="<%= bettingView.view %>">
                      <input type="hidden" name="type" value="series">
                      <input type="hidden" name="bet_id" value="<%= s.currentBet.id %>">
                      <button type="submit" class="cancel-bet-button">Cancel Bet</button>
                    </form>
                  <% } %>
                </div>
              <% } else { %>
                <p class="muted compact-no-bet"><%= s.bettingClosed ? 'No bet placed before this series closed.' : 'No bet placed.' %></p>
              <% } %>
            </div>

            <% if (!bettingView.locked && !s.bettingClosed) { %>
              <form method="post" action="/bets" class="builder-form compact-builder-form">
                <input type="hidden" name="view" value="<%= bettingView.view %>">
                <input type="hidden" name="series_key" value="<%= s.series_key %>">
                <input type="hidden" name="market_key" value="<%= s.currentBet ? s.currentBet.market_key : '' %>" data-market-input required>
                <input type="hidden" name="goal_total_side" value="<%= s.currentBet && s.currentBet.goal_total_side ? s.currentBet.goal_total_side : '' %>" data-goal-total-input>
                <input type="hidden" name="goal_total_line" value="<%= s.goalTotal.line %>" data-goal-total-line>
                <input type="hidden" value="<%= s.goalTotal.boost %>" data-goal-total-boost>

                <% s.markets.forEach(m => { %>
                  <input
                    type="hidden"
                    data-market-option
                    data-team-id="<%= m.team_id %>"
                    data-type="<%= m.type %>"
                    data-market-key="<%= m.market_key %>"
                    data-multiplier="<%= m.multiplier %>"
                    data-label="<%= m.label %>"
                  >
                <% }) %>

                <div class="compact-control-row">
                  <label class="stake-label compact-stake inline-stake">
                    <span class="step-label">Stake</span>
                    <input name="stake" type="number" min="1" max="<%= maxBet %>" step="1" placeholder="Stake" value="<%= s.currentBet ? s.currentBet.stake : '' %>" data-stake-input required>
                  </label>

                  <div class="builder-step compact-step">
                    <span class="step-label">Winner</span>
                    <div class="choice-row compact-choice-row">
                      <button type="button" class="choice-btn team-choice" data-team-id="<%= s.away_team_id %>"><%= s.away_team_name %></button>
                      <button type="button" class="choice-btn team-choice" data-team-id="<%= s.home_team_id %>"><%= s.home_team_name %></button>
                    </div>
                  </div>

                  <div class="builder-step compact-step risk-step" data-risk-step>
                    <span class="step-label">Result</span>
                    <div class="choice-row compact-choice-row risk-row">
                      <button type="button" class="choice-btn risk-choice" data-type="series_win">Series win <span data-risk-odds="series_win">2x</span></button>
                      <button type="button" class="choice-btn risk-choice" data-type="exact_2_1">2-1 <span data-risk-odds="exact_2_1">3x</span></button>
                      <button type="button" class="choice-btn risk-choice" data-type="sweep_3_0">3-0 sweep <span data-risk-odds="sweep_3_0">4x</span></button>
                    </div>
                  </div>

                  <div class="builder-step compact-step goal-total-step">
                    <span class="step-label">O/U <%= s.goalTotal.line %> Goals <span class="boost-mult">(+<%= s.goalTotal.boost %>x)</span></span>
                    <div class="choice-row compact-choice-row goal-total-row">
                      <button type="button" class="choice-btn goal-total-choice <%= s.currentBet && s.currentBet.goal_total_side === 'over' ? 'selected' : '' %>" data-goal-total-side="over">Over</button>
                      <button type="button" class="choice-btn goal-total-choice <%= s.currentBet && s.currentBet.goal_total_side === 'under' ? 'selected' : '' %>" data-goal-total-side="under">Under</button>
                    </div>
                  </div>
                </div>

                <div class="builder-actions compact-builder-actions">
                  <div class="builder-summary compact-summary" data-summary hidden>
                    <span data-summary-text>Select a team and result.</span>
                    <strong data-return-text></strong>
                  </div>
                  <button class="place-button"><%= s.currentBet ? 'Update Bet' : 'Place Bet' %></button>
                </div>
              </form>
            <% } %>
          </article>
        <% }) %>
      </section>
    <% } else { %>
      <section class="board compact-board prop-board">
        <% propBoards.forEach(div => { %>
          <article class="card prop-division-card">
            <div class="series-head compact-series-head prop-division-head">
              <div>
                <span class="pill"><%= div.division_name %></span>
                <h2><%= div.division_name %> Prop Bets</h2>
                <% if (div.bettingClosed) { %>
                  <p class="negative compact-no-bet">Prop betting is closed because a series in this division is complete.</p>
                <% } %>
              </div>
              <p class="muted compact-no-bet">Max prop bet: <strong><%= propMaxBet %></strong> Mushybux</p>
            </div>

            <div class="prop-grid">
              <% div.categories.forEach((prop, propIdx) => { %>
                <div class="prop-card prop-builder" data-prop-index="<%= div.division_id %>-<%= propIdx %>">
                  <div class="prop-card-head">
                    <div>
                      <h3><%= prop.title %></h3>
                      <p class="muted"><%= prop.description %></p>
                    </div>
                    <% if (prop.currentBet) { %>
                      <%
                        const propBetSettled = prop.currentBet.status === 'settled';
                        const propBetWon = propBetSettled && (prop.currentBet.won || Number(prop.currentBet.payout || 0) > 0);
                        const propBetStateClass = propBetSettled ? (propBetWon ? 'bet-won' : 'bet-lost') : 'bet-pending';
                        const propBetStateLabel = propBetSettled ? (propBetWon ? 'Won' : 'Lost') : 'Pending';
                      %>
                      <div class="current-bet-box compact-current-bet prop-current-bet <%= propBetStateClass %>">
                        <span class="pill"><%= propBetStateLabel %></span>
                        <strong><%= prop.currentBet.label.split(': ').pop() %></strong>
                        <% if (propBetSettled) { %>
                          <span><%= prop.currentBet.stake %> Mushybux · <%= prop.currentBet.multiplier %>x · Payout <strong><%= Number(prop.currentBet.payout || 0) %></strong></span>
                        <% } else { %>
                          <span><%= prop.currentBet.stake %> Mushybux · <%= prop.currentBet.multiplier %>x · Return <strong><%= Math.ceil(Number(prop.currentBet.stake) * Number(prop.currentBet.multiplier)) %></strong></span>
                        <% } %>
                        <% if (!propBetSettled && !bettingView.locked && !div.bettingClosed) { %>
                          <form method="post" action="/bets/cancel" class="cancel-bet-form" onsubmit="return confirm('Cancel this prop bet and return <%= prop.currentBet.stake %> Mushybux?');">
                            <input type="hidden" name="view" value="<%= bettingView.view %>">
                            <input type="hidden" name="type" value="props">
                            <input type="hidden" name="bet_id" value="<%= prop.currentBet.id %>">
                            <button type="submit" class="cancel-bet-button">Cancel Prop</button>
                          </form>
                        <% } %>
                      </div>
                    <% } else { %>
                      <p class="muted compact-no-bet">No bet placed.</p>
                    <% } %>
                  </div>

                  <% if (!bettingView.locked && !div.bettingClosed) { %>
                    <form method="post" action="/prop-bets" class="builder-form compact-builder-form prop-form">
                      <input type="hidden" name="view" value="<%= bettingView.view %>">
                      <input type="hidden" name="prop_key" value="<%= prop.prop_key %>">

                      <div class="prop-control-row <%= prop.quantity_options.length ? '' : 'no-quantity' %>">
                        <label class="stake-label compact-stake inline-stake">
                          <span class="step-label">Stake</span>
                          <input name="stake" type="number" min="1" max="<%= propMaxBet %>" step="1" placeholder="Stake" value="<%= prop.currentBet ? prop.currentBet.stake : '' %>" data-prop-stake-input required>
                        </label>

                        <label class="prop-select-label">
                          <span class="step-label">Player</span>
                          <select name="player_key" data-prop-player required>
                            <option value="">Select player</option>
                            <% prop.players.forEach(player => { %>
                              <option
                                value="<%= player.selection_key || player.player_key %>"
                                data-player-name="<%= player.display_name %>"
                                data-player-multiplier="<%= player.prop_multiplier || prop.multiplier %>"
                                data-player-q1="<%= player.prop_quantity_multipliers ? player.prop_quantity_multipliers[1] : '' %>"
                                data-player-q2="<%= player.prop_quantity_multipliers ? player.prop_quantity_multipliers[2] : '' %>"
                                data-player-q3="<%= player.prop_quantity_multipliers ? player.prop_quantity_multipliers[3] : '' %>"
                                data-player-q1-label="<%= player.prop_quantity_labels ? player.prop_quantity_labels[1] : '' %>"
                                data-player-q2-label="<%= player.prop_quantity_labels ? player.prop_quantity_labels[2] : '' %>"
                                data-player-q3-label="<%= player.prop_quantity_labels ? player.prop_quantity_labels[3] : '' %>"
                                <%= prop.currentBet && (prop.currentBet.market_key === player.selection_key || (!player.selection_key && prop.currentBet.player_key === player.player_key)) ? 'selected' : '' %>
                              ><%= player.option_label || `${player.display_name} - ${player.prop_multiplier || prop.multiplier}x` %></option>
                            <% }) %>
                          </select>
                        </label>

                        <% if (prop.quantity_options.length) { %>
                          <div class="builder-step compact-step prop-result-step">
                            <span class="step-label">Result</span>
                            <input type="hidden" name="quantity" value="<%= prop.currentBet && prop.currentBet.quantity ? prop.currentBet.quantity : '' %>" data-prop-quantity required>
                            <div class="choice-row compact-choice-row risk-row prop-quantity-row">
                              <% prop.quantity_options.forEach(q => { %>
                                <button
                                  type="button"
                                  class="choice-btn prop-quantity-choice <%= prop.currentBet && Number(prop.currentBet.quantity) === Number(q.quantity) ? 'selected' : '' %>"
                                  data-quantity="<%= q.quantity %>"
                                  data-label="<%= q.label %>"
                                  data-multiplier="<%= q.multiplier %>"
                                ><%= q.label %> <span><%= q.multiplier %>x</span></button>
                              <% }) %>
                            </div>
                          </div>
                        <% } else { %>
                          <input type="hidden" name="quantity" value="">
                          <input type="hidden" data-fixed-multiplier value="<%= prop.multiplier %>">
                        <% } %>
                      </div>

                      <div class="builder-actions compact-builder-actions">
                        <div class="builder-summary compact-summary" data-prop-summary hidden>
                          <span data-prop-summary-text>Select a player.</span>
                          <strong data-prop-return-text></strong>
                        </div>
                        <button class="place-button"><%= prop.currentBet ? 'Update Prop' : 'Place Prop' %></button>
                      </div>
                    </form>
                  <% } %>
                </div>
              <% }) %>
            </div>
          </article>
        <% }) %>
      </section>
    <% } %>
  </main>

  <script>
    document.querySelectorAll('.bet-builder').forEach(card => {
      const teamButtons = [...card.querySelectorAll('.team-choice')];
      const riskButtons = [...card.querySelectorAll('.risk-choice')];
      const goalTotalButtons = [...card.querySelectorAll('.goal-total-choice')];
      const marketOptions = [...card.querySelectorAll('[data-market-option]')];
      const marketInput = card.querySelector('[data-market-input]');
      const goalTotalInput = card.querySelector('[data-goal-total-input]');
      const goalTotalLineInput = card.querySelector('[data-goal-total-line]');
      const stakeInput = card.querySelector('[data-stake-input]');
      const summary = card.querySelector('[data-summary]');
      const summaryText = card.querySelector('[data-summary-text]');
      const returnText = card.querySelector('[data-return-text]');

      if (!marketInput) return;

      let selectedTeamId = '';
      let selectedType = 'series_win';
      let selectedMultiplier = 0;
      let selectedLabel = '';
      let selectedGoalTotalSide = goalTotalInput?.value || '';
      const goalTotalLine = goalTotalLineInput?.value || '10.5';
      const goalTotalBoost = Number(card.querySelector('[data-goal-total-boost]')?.value || 1.5);

      function findMarket(teamId, type) {
        return marketOptions.find(m => m.dataset.teamId === teamId && m.dataset.type === type);
      }

      function refreshRiskOdds() {
        if (!selectedTeamId) return;
        riskButtons.forEach(button => {
          const market = findMarket(selectedTeamId, button.dataset.type);
          const span = button.querySelector('[data-risk-odds]');
          if (market && span) span.textContent = `${market.dataset.multiplier}x`;
        });
      }

      function applySelection() {
        if (!selectedTeamId) return;
        refreshRiskOdds();
        const market = findMarket(selectedTeamId, selectedType) || findMarket(selectedTeamId, 'series_win');
        if (!market) return;

        selectedType = market.dataset.type;
        marketInput.value = market.dataset.marketKey;
        selectedMultiplier = Number(market.dataset.multiplier || 0);
        selectedLabel = market.dataset.label || '';

        riskButtons.forEach(b => b.classList.toggle('selected', b.dataset.type === selectedType));
        updateSummary();
      }

      function updateSummary() {
        if (!marketInput.value || !summary) return;
        const stake = Number(stakeInput.value || 0);
        const boostedMultiplier = selectedGoalTotalSide ? Number((selectedMultiplier * goalTotalBoost).toFixed(2)) : selectedMultiplier;
        const ouLabel = selectedGoalTotalSide ? ` + ${selectedGoalTotalSide === 'over' ? 'Over' : 'Under'} ${goalTotalLine}` : '';
        summary.hidden = false;
        summaryText.textContent = `${selectedLabel || 'Selection ready.'}${ouLabel}`;
        returnText.textContent = stake > 0 && boostedMultiplier > 0
          ? `Potential return: ${Math.ceil(stake * boostedMultiplier)} Mushybux`
          : '';
      }

      teamButtons.forEach(button => {
        button.addEventListener('click', () => {
          selectedTeamId = button.dataset.teamId;
          teamButtons.forEach(b => b.classList.remove('selected'));
          button.classList.add('selected');
          applySelection();
        });
      });

      riskButtons.forEach(button => {
        button.addEventListener('click', () => {
          selectedType = button.dataset.type;
          applySelection();
        });
      });

      function updateGoalTotalButtons() {
        goalTotalButtons.forEach(b => b.classList.toggle('selected', b.dataset.goalTotalSide === selectedGoalTotalSide));
        if (goalTotalInput) goalTotalInput.value = selectedGoalTotalSide;
        updateSummary();
      }

      goalTotalButtons.forEach(button => {
        button.addEventListener('click', () => {
          const side = button.dataset.goalTotalSide;
          selectedGoalTotalSide = selectedGoalTotalSide === side ? '' : side;
          updateGoalTotalButtons();
        });
      });

      stakeInput?.addEventListener('input', updateSummary);

      const existingMarket = marketInput.value;
      if (existingMarket) {
        const existingOption = marketOptions.find(m => m.dataset.marketKey === existingMarket);
        if (existingOption) {
          const existingTeam = teamButtons.find(b => b.dataset.teamId === existingOption.dataset.teamId);
          selectedType = existingOption.dataset.type || 'series_win';
          existingTeam?.click();
          applySelection();
        }
      }
      updateGoalTotalButtons();
    });

    document.querySelectorAll('.prop-builder').forEach(card => {
      const form = card.querySelector('.prop-form');
      if (!form) return;

      const playerSelect = form.querySelector('[data-prop-player]');
      const stakeInput = form.querySelector('[data-prop-stake-input]');
      const quantityInput = form.querySelector('[data-prop-quantity]');
      const quantityButtons = [...form.querySelectorAll('.prop-quantity-choice')];
      const fixedMultiplierInput = form.querySelector('[data-fixed-multiplier]');
      const summary = form.querySelector('[data-prop-summary]');
      const summaryText = form.querySelector('[data-prop-summary-text]');
      const returnText = form.querySelector('[data-prop-return-text]');

      let multiplier = Number(fixedMultiplierInput?.value || 0);
      let quantityLabel = '';

      function updatePropSummary() {
        if (!summary) return;
        const selectedOption = playerSelect?.selectedOptions?.[0];
        const playerName = selectedOption?.dataset?.playerName || selectedOption?.textContent || '';
        if (!quantityButtons.length && selectedOption?.dataset?.playerMultiplier) {
          multiplier = Number(selectedOption.dataset.playerMultiplier || multiplier);
        }
        if (quantityButtons.length && quantityInput?.value && selectedOption) {
          const qMult = selectedOption.dataset[`playerQ${quantityInput.value}`];
          const selectedButton = quantityButtons.find(b => b.dataset.quantity === quantityInput.value);
          multiplier = Number(qMult || selectedButton?.dataset.multiplier || multiplier);
          quantityLabel = selectedOption.dataset[`playerQ${quantityInput.value}Label`] || selectedButton?.dataset.label || '';
        }
        const stake = Number(stakeInput?.value || 0);

        if (!playerSelect?.value) {
          summary.hidden = true;
          return;
        }

        if (quantityButtons.length && !quantityInput.value) {
          summary.hidden = false;
          summaryText.textContent = `${playerName}: select result.`;
          returnText.textContent = '';
          return;
        }

        summary.hidden = false;
        summaryText.textContent = quantityLabel ? `${playerName} · ${quantityLabel} · ${multiplier}x` : `${playerName} · ${multiplier}x`;
        returnText.textContent = stake > 0 && multiplier > 0
          ? `Potential return: ${Math.ceil(stake * multiplier)} Mushybux`
          : '';
      }

      quantityButtons.forEach(button => {
        button.addEventListener('click', () => {
          quantityButtons.forEach(b => b.classList.remove('selected'));
          button.classList.add('selected');
          quantityInput.value = button.dataset.quantity;
          multiplier = Number(button.dataset.multiplier || 0);
          quantityLabel = button.dataset.label || '';
          updatePropSummary();
        });
      });

      playerSelect?.addEventListener('change', () => {
        const selectedOption = playerSelect.selectedOptions?.[0];
        quantityButtons.forEach(button => {
          const quantity = button.dataset.quantity;
          const label = selectedOption?.dataset?.[`playerQ${quantity}Label`] || button.dataset.label || '';
          const odds = selectedOption?.dataset?.[`playerQ${quantity}`] || button.dataset.multiplier || '';
          button.innerHTML = `${label || `Tier ${quantity}`} <span>${odds}x</span>`;
        });
        updatePropSummary();
      });
      stakeInput?.addEventListener('input', updatePropSummary);

      const selectedQuantity = quantityButtons.find(b => b.classList.contains('selected'));
      if (selectedQuantity) {
        multiplier = Number(selectedQuantity.dataset.multiplier || 0);
        quantityLabel = selectedQuantity.dataset.label || '';
      }
      playerSelect?.dispatchEvent(new Event('change'));
      updatePropSummary();
    });
  </script>
</body>
</html>
