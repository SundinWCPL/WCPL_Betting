<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>WCPL Betting</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials_header') %>

  <%
  function formatScheduleDateTime(value) {
    const v = String(value || '').trim();
    if (!v) return '';

    const m = v.match(/^(\d{4})-(\d{2})-(\d{2})(?:[ T](\d{1,2}):(\d{2}))?/);
    if (!m) return v;

    const [, yyyy, mm, dd, hh, min] = m;

    const d = new Date(
      Number(yyyy),
      Number(mm) - 1,
      Number(dd),
      hh ? Number(hh) : 0,
      min ? Number(min) : 0
    );

    return d.toLocaleString(undefined, {
      month: 'short',
      day: 'numeric',
      hour: 'numeric',
      minute: '2-digit'
    });
  }
  %>

  <main class="container">
    <section class="hero card">
      <div>
        <p class="eyebrow">Season 3 · Week <%= currentWeek %></p>
        <h1>Leaderboard & Weekly Betting Board</h1>
        <p>Track the Mushybux race, weekly movement, and where the league is putting its Mushybux.</p>
        <% if (currentUserBalance) { %>
          <p class="balance-line">Your Mushybux: <strong><%= currentUserBalance.display %></strong> <span class="muted"> - total (wagered)</span></p>
        <% } %>
      </div>
      <% if (!currentUser) { %><a class="primary" href="/login">Login to bet</a><% } else { %><a class="primary" href="/betting">Place bets</a><% } %>
    </section>

    <section class="grid two">
      <div class="card">
        <div class="admin-section-head">
          <div>
            <h2>Leaderboard</h2>
            <p class="muted" data-leaderboard-description>League betting balances only.</p>
          </div>
          <div class="toggle-row">
            <button class="button-link ghost-active" type="button" data-leaderboard-mode="betting">Betting</button>
            <button class="button-link ghost" type="button" data-leaderboard-mode="overall">Overall</button>
          </div>
        </div>
		<div class="leaderboard-scroll">
		<table>
          <thead><tr><th>#</th><th>User</th><th>Mushybux</th><th>Current Week</th><th>Last Week</th></tr></thead>
          <tbody data-leaderboard-table="betting">
            <% leaderboard.forEach((u, i) => { %>
              <tr class="<%= currentUser && Number(currentUser.id) === Number(u.id) ? 'self-row' : '' %>">
                <td><%= i + 1 %></td>
                <td><%= u.display_name %></td>
                <td><%= u.balance_display %></td>
                <td class="<%= Number(u.current_week_change) > 0 ? 'positive' : (Number(u.current_week_change) < 0 ? 'negative' : 'muted') %>"><%= u.current_week_display %></td>
                <td class="<%= Number(u.last_week_change) > 0 ? 'positive' : (Number(u.last_week_change) < 0 ? 'negative' : 'muted') %>"><%= u.last_week_display %></td>
              </tr>
            <% }) %>
          </tbody>
          <tbody data-leaderboard-table="overall" hidden>
            <% overallLeaderboard.forEach((u, i) => { %>
              <tr class="<%= currentUser && Number(currentUser.id) === Number(u.id) ? 'self-row' : '' %>">
                <td><%= i + 1 %></td>
                <td><%= u.display_name %></td>
                <td><%= u.balance_display %></td>
                <td class="<%= Number(u.current_week_change) > 0 ? 'positive' : (Number(u.current_week_change) < 0 ? 'negative' : 'muted') %>"><%= u.current_week_display %></td>
                <td class="<%= Number(u.last_week_change) > 0 ? 'positive' : (Number(u.last_week_change) < 0 ? 'negative' : 'muted') %>"><%= u.last_week_display %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
		</div>
        <p class="small-note">Betting excludes casino wins and losses. Overall shows each user’s actual combined balance. Open sports wagers remain included in both.</p>
      </div>

      <div class="card">
        <h2>Top Bets This Week</h2>
        <% if (!topBets.length) { %>
          <p class="muted">No bets placed yet.</p>
        <% } else { %>
          <table>
            <thead><tr><th>Bet</th><th>Mushybux</th><th>Bets</th></tr></thead>
            <tbody>
              <% topBets.forEach(t => { %>
                <tr><td><%= t.label %></td><td><%= t.total_stake %></td><td><%= t.bet_count %></td></tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </section>

    <section class="card">
      <h2>Week <%= currentWeek %> Matchups</h2>
      <div class="matchup-columns">
        <% matchupGroups.forEach(group => { %>
          <div class="division-matchups">
            <h3><%= group.division_name %></h3>
            <div class="matchup-list compact-matchup-list">
              <% group.series.forEach(s => { %>
                <div class="matchup-row compact-matchup-row compact-matchup-card">
                  <div class="matchup-line">
                    <strong>
                      <span
                        class="community-odds <%= s.away_community_odds.favorite ? 'favorite' : '' %> <%= s.away_community_odds.underdog ? 'underdog' : '' %>"
                        style="--odds-intensity:<%= s.away_community_odds.intensity || 0 %>"
                        title="<%= s.away_community_odds.title %>"
                      ><%= s.away_community_odds.odds %></span>
                      <%= s.away_team_name %>
                    </strong>
                    <span>at</span>
                    <strong>
                      <%= s.home_team_name %>
                      <span
                        class="community-odds <%= s.home_community_odds.favorite ? 'favorite' : '' %> <%= s.home_community_odds.underdog ? 'underdog' : '' %>"
                        style="--odds-intensity:<%= s.home_community_odds.intensity || 0 %>"
                        title="<%= s.home_community_odds.title %>"
                      ><%= s.home_community_odds.odds %></span>
                    </strong>
                  </div>

                  <div class="matchup-result-row">
                    <% if (s.result_label) { %>
                      <% if (s.result_boxscore_url) { %>
                        <a class="matchup-result-badge" href="<%= s.result_boxscore_url %>" target="_blank" rel="noopener"><%= s.result_label %></a>
                      <% } else { %>
                        <span class="matchup-result-badge"><%= s.result_label %></span>
                      <% } %>
                    <% } else { %>
                      <%
const scheduledTime =
  s.games?.find(g => String(g.imported_on || '').trim())?.imported_on;
%>

<span class="matchup-result-badge matchup-result-tbd">
  <%= scheduledTime
      ? formatScheduleDateTime(scheduledTime)
      : 'TBD' %>
</span>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </main>
  <script>
    (() => {
      const buttons = [...document.querySelectorAll('[data-leaderboard-mode]')];
      const tables = [...document.querySelectorAll('[data-leaderboard-table]')];
      const description = document.querySelector('[data-leaderboard-description]');

      buttons.forEach(button => button.addEventListener('click', () => {
        const mode = button.dataset.leaderboardMode || 'betting';
        buttons.forEach(candidate => {
          const active = candidate.dataset.leaderboardMode === mode;
          candidate.classList.toggle('ghost-active', active);
          candidate.classList.toggle('ghost', !active);
        });
        tables.forEach(table => {
          table.hidden = table.dataset.leaderboardTable !== mode;
        });
        if (description) {
          description.textContent = mode === 'overall'
            ? 'Sports betting and casino results combined.'
            : 'League betting balances only.';
        }
      }));
    })();
  </script>
</body>
</html>
