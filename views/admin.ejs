<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin · WCPL Betting</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials_header') %>

  <main class="container">
    <section class="card page-title compact-title">
      <div>
        <p class="eyebrow">Commissioner Controls</p>
        <h1>Admin Panel</h1>
        <p>
          Season: <strong><%= settings.seasonId %></strong> ·
          Current Week: <strong><%= currentWeek %></strong> ·
          Next Week Review: <strong><%= nextWeek %></strong> ·
          Preparing Week: <strong><%= nextWeek %></strong>
        </p>
        <p class="muted">
          Week <%= currentWeek %> status:
          <strong class="<%= settings.currentWeekLocked ? 'negative' : 'positive' %>">
            <%= settings.currentWeekLocked ? 'Locked' : 'Open' %>
          </strong>
          · Week <%= nextWeek %> lines:
          <strong>
            Not published
          </strong>
        </p>
      </div>
    </section>

    <section class="admin-grid">
      <article class="card admin-card">
        <h2>League Controls</h2>

        <form method="post" action="/admin/season" class="admin-inline-form" onsubmit="return confirm('Switch season and reset the debug week to Week 1?');">
          <label>
            Debug season
            <select name="season_id">
              <% seasons.forEach(season => { %>
                <option value="<%= season %>" <%= season === settings.seasonId ? 'selected' : '' %>><%= season %></option>
              <% }) %>
            </select>
          </label>
          <button type="submit">Switch Season</button>
        </form>

        <div class="admin-action-row">
          <% if (settings.currentWeekLocked) { %>
            <form method="post" action="/admin/unlock">
              <button>Unlock Week <%= currentWeek %></button>
            </form>
          <% } else { %>
            <form method="post" action="/admin/lock">
              <button>Lock Week <%= currentWeek %></button>
            </form>
          <% } %>
        </div>

        <p class="muted small-note">
          Betting is available only for the current week. Lock it shortly before the first series begins.
        </p>

        <form method="post" action="/admin/allowance" class="admin-inline-form">
          <label>
            Weekly allowance
            <input type="number" name="weekly_allowance" min="0" step="1" value="<%= settings.weeklyAllowance %>">
          </label>
          <button type="submit">Save Allowance</button>
        </form>

        <form method="post" action="/admin/advance-week" class="admin-danger-zone" onsubmit="return confirm('Advance to Week <%= currentWeek + 1 %>? This will be blocked if any Week <%= currentWeek %> bets are still unsettled.');">
          <div>
            <strong>Advance Week</strong>
            <p class="muted">Publishes the reviewed Week <%= currentWeek + 1 %> lines, opens betting, applies allowance, and refunds any open bets from the retired hat-trick market. Existing series bets inherit the published line and payout.</p>
          </div>
          <button type="submit">Advance Week</button>
        </form>
      </article>

      <article class="card admin-card">
        <h2>Testing / Emergency Resets</h2>

        <form method="post" action="/admin/reset-week-bets" class="admin-danger-zone" onsubmit="return confirm('Void all Week <%= currentWeek %> bets and refund stakes?');">
          <input type="hidden" name="week" value="<%= currentWeek %>">
          <div>
            <strong>Reset Current Week Bets</strong>
            <p class="muted">Voids all open bets for Week <%= currentWeek %> and refunds stakes.</p>
          </div>
          <button type="submit">Void Week <%= currentWeek %> Bets</button>
        </form>

        <form method="post" action="/admin/reset-all-data" class="admin-danger-zone hard-reset" onsubmit="return confirm('Reset ALL test data? This clears bets, transactions, balances, and restores seeded users.');">
          <div>
            <strong>Reset All Test Data</strong>
            <p class="muted">Clears the JSON database back to seeded users and starting Mushybux.</p>
          </div>
          <button type="submit">Reset All Data</button>
        </form>
      </article>
    </section>

    <section class="card admin-card" id="casino-controls">
      <div class="admin-section-head">
        <div>
          <p class="eyebrow">Casino Operations</p>
          <h2>Casino Controls</h2>
        </div>
        <span class="pill <%= settings.casinoOpen ? 'positive' : 'negative' %>">
          <%= settings.casinoOpen ? 'Open' : 'Closed' %>
        </span>
      </div>

      <div class="casino-admin-metrics">
        <div>
          <span class="muted">Amount Wagered</span>
          <strong><%= Number(casinoSummary.totalWagered || 0).toLocaleString() %></strong>
        </div>
        <div>
          <span class="muted">Amount Won</span>
          <strong><%= Number(casinoSummary.totalPaid || 0).toLocaleString() %></strong>
        </div>
        <div>
          <span class="muted">Net Profit</span>
          <strong class="<%= Number(casinoSummary.netProfit || 0) >= 0 ? 'positive' : 'negative' %>">
            <%= Number(casinoSummary.netProfit || 0).toLocaleString() %>
          </strong>
        </div>
      </div>

      <div class="admin-action-row">
        <% if (settings.casinoOpen) { %>
          <form method="post" action="/admin/casino/close">
            <button type="submit">Close Casino</button>
          </form>
        <% } else { %>
          <form method="post" action="/admin/casino/open">
            <button type="submit">Open Casino</button>
          </form>
        <% } %>

        <% if (settings.casinoLinkVisible) { %>
          <form method="post" action="/admin/casino/hide-link">
            <button type="submit">Hide Casino Link</button>
          </form>
        <% } else { %>
          <form method="post" action="/admin/casino/show-link">
            <button type="submit">Show Casino Link</button>
          </form>
        <% } %>
      </div>

      <p class="muted small-note">
        Navigation link: <strong><%= settings.casinoLinkVisible ? 'Visible' : 'Hidden' %></strong>.
        Closing the casino disables slots and Puck IQ even when someone enters the URL manually.
      </p>

      <form method="post" action="/admin/casino/reset" class="admin-danger-zone hard-reset" onsubmit="return confirm('Reset ALL casino data? This removes every slot spin and Puck IQ run, deletes casino ledger entries, and restores user balances as though the casino activity never happened.');">
        <div>
          <strong>Reset Casino Data</strong>
          <p class="muted">Wipes all casino history and reverses every user’s casino winnings or losses.</p>
        </div>
        <button type="submit">Reset Casino Data</button>
      </form>
    </section>



    <section class="card admin-card" id="user-balances">
      <h2>Backups</h2>
      <p class="muted">
        Database file: <code><%= backupInfo.backupDir %></code>
      </p>
      <% if (backupInfo.latestBackup) { %>
        <p class="muted">
          Latest server backup:
          <strong><%= backupInfo.latestBackup.name %></strong>
          · <%= new Date(backupInfo.latestBackup.createdAt).toLocaleString() %>
        </p>
      <% } else { %>
        <p class="muted">No server backups created yet.</p>
      <% } %>
      <div class="admin-action-row">
        <form method="post" action="/admin/backup/create">
          <button type="submit">Create Server Backup</button>
        </form>
        <a class="button-link ghost" href="/admin/backup/download">Download Backup</a>
      </div>
      <p class="muted small-note">Use this after settling/advancing each week. Server backups are saved beside the JSON database, which should be on the Railway volume.</p>
    </section>

    <section class="card admin-card">
      <h2>Add User</h2>
      <form method="post" action="/admin/add-user" class="admin-user-form">
        <label>
          Display name
          <input type="text" name="display_name" placeholder="Logan" required>
        </label>
        <label>
          Username
          <input type="text" name="username" placeholder="username" required>
        </label>
        <label>
          Password
          <input type="text" name="password" placeholder="Temporary password" required>
        </label>
        <label>
          Role
          <select name="role">
            <option value="user">User</option>
            <option value="admin">Admin</option>
          </select>
        </label>
        <button type="submit">Add User</button>
      </form>
    </section>


    <section class="card admin-card">
      <div class="admin-section-head">
        <h2>Void / Refund Tools · Week <%= currentWeek %></h2>
        <button type="button" class="button-link ghost admin-collapse-toggle" data-target="adminVoidRefundBody">Show</button>
      </div>
      <div id="adminVoidRefundBody" class="admin-collapsible-body" hidden>
      <p class="muted">Use this before moving a postponed series out of the week in the main WCPL schedule. It refunds matching open series bets plus prop bets on players from either team.</p>

      <form method="post" action="/admin/void-series" class="admin-inline-form" onsubmit="return confirm('Void/refund all open bets tied to this series, including props for players on both teams?');">
        <input type="hidden" name="week" value="<%= currentWeek %>">
        <label>
          Postponed series
          <select name="series_key" required>
            <option value="">Select series...</option>
            <% currentWeekSeries.forEach(s => { %>
              <option value="<%= s.series_key %>"><%= s.division_name %> · <%= s.away_team_name %> at <%= s.home_team_name %></option>
            <% }) %>
          </select>
        </label>
        <button type="submit">Void Series + Team Props</button>
      </form>

      <% if (voidRefunds && voidRefunds.length) { %>
        <h3>Current Week Void/Refund Recap</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>User</th>
                <th>Refund</th>
                <th>Reason</th>
                <th>Time</th>
              </tr>
            </thead>
            <tbody>
              <% voidRefunds.forEach(v => { %>
                <tr>
                  <td><%= v.user_display_name %></td>
                  <td><%= v.amount %></td>
                  <td><%= v.note %></td>
                  <td><%= new Date(v.created_at).toLocaleString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="muted">No Week <%= currentWeek %> void/refund actions yet.</p>
      <% } %>
      </div>
    </section>

    <section class="card admin-card">
      <div class="admin-section-head">
        <h2>Settlement Preview · Week <%= currentWeek %></h2>
        <button type="button" class="button-link ghost admin-collapse-toggle" data-target="adminSettlementPreviewBody">Show</button>
      </div>
      <div id="adminSettlementPreviewBody" class="admin-collapsible-body" hidden>
      <% if (settlementPreview && settlementPreview.error) { %>
        <p class="negative">Unable to build settlement preview: <%= settlementPreview.error %></p>
      <% } else if (settlementPreview) { %>
        <p class="muted">
          Ready: <strong class="<%= settlementPreview.ready ? 'positive' : 'negative' %>"><%= settlementPreview.ready ? 'Yes' : 'No' %></strong> ·
          Winners: <strong><%= settlementPreview.winners %></strong> ·
          Losers: <strong><%= settlementPreview.losers %></strong> ·
          Skipped: <strong><%= settlementPreview.skipped %></strong> ·
          Payout: <strong><%= settlementPreview.payoutTotal %></strong> Mushybux
        </p>

        <div class="admin-action-row">
          <form method="post" action="/admin/settle-completed" class="admin-danger-zone" onsubmit="return confirm('Settle every currently resolved Week <%= currentWeek %> bet? Unresolved bets will stay in the preview.');">
            <input type="hidden" name="week" value="<%= currentWeek %>">
            <div>
              <strong>Settle Completed Bets</strong>
              <p class="muted">Pays only bets that are resolved right now. Settled bets disappear from this preview.</p>
            </div>
            <button type="submit">Settle Completed Bets</button>
          </form>

          <form method="post" action="/admin/settle-week" class="admin-danger-zone" onsubmit="return confirm('Settle every open Week <%= currentWeek %> bet? This only works when the entire week is ready.');">
            <input type="hidden" name="week" value="<%= currentWeek %>">
            <div>
              <strong>Settle Entire Week</strong>
              <p class="muted">Only enabled when every open Week <%= currentWeek %> bet is complete.</p>
            </div>
            <button type="submit" <%= settlementPreview.ready ? '' : 'disabled' %>>Settle Entire Week</button>
          </form>
        </div>

        <% if (settlementPreview.rows.length) { %>
          <div class="settlement-preview-controls">
            <label>
              Sort preview
              <select id="settlementPreviewSort">
                <option value="original">Original order</option>
                <option value="ready">Complete first</option>
                <option value="incomplete">Incomplete first</option>
                <option value="result">Win/Loss/Incomplete</option>
                <option value="payout_desc">Payout high to low</option>
                <option value="stake_desc">Stake high to low</option>
                <option value="stake_asc">Stake low to high</option>
                <option value="user_asc">User A-Z</option>
                <option value="bet_asc">Bet A-Z</option>
              </select>
            </label>
            <label class="settlement-preview-checkbox">
              <input type="checkbox" id="settlementPreviewHideIncomplete">
              Hide incomplete bets
            </label>
          </div>

          <div class="table-wrap">
            <table id="settlementPreviewTable">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Bet</th>
                  <th>Stake</th>
                  <th>Odds</th>
                  <th>Result</th>
                  <th>Payout</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% settlementPreview.rows.forEach((r, idx) => { %>
                  <tr
                    data-original-index="<%= idx %>"
                    data-ready="<%= r.ready ? '1' : '0' %>"
                    data-won="<%= r.ready ? (r.won ? '1' : '0') : '' %>"
                    data-user="<%= r.user_display_name %>"
                    data-bet="<%= r.label %>"
                    data-stake="<%= Number(r.stake || 0) %>"
                    data-multiplier="<%= Number(r.multiplier || 0) %>"
                    data-payout="<%= Number(r.payout || 0) %>"
                  >
                    <td><%= r.user_display_name %></td>
                    <td><%= r.label %></td>
                    <td><%= r.stake %></td>
                    <td><%= r.multiplier %>x</td>
                    <td>
                      <% if (!r.ready) { %>
                        <span class="negative">Incomplete</span>
                      <% } else if (r.won) { %>
                        <span class="positive">Win</span>
                      <% } else { %>
                        <span class="negative">Loss</span>
                      <% } %>
                      <br><small class="muted"><%= r.result_summary || r.evaluation_reason %></small>
                    </td>
                    <td><%= r.payout %></td>
                    <td>
                      <form method="post" action="/admin/refund-bet" onsubmit="return confirm('Refund and void this bet?');">
                        <input type="hidden" name="bet_id" value="<%= r.id %>">
                        <button type="submit" class="ghost small-button">Refund</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="muted">No open Week <%= currentWeek %> bets to settle.</p>
        <% } %>
      <% } %>
      </div>
    </section>

    <section class="card admin-card">
      <div class="admin-section-head">
        <h2>User Balances & Details</h2>
        <button type="button" class="button-link ghost admin-collapse-toggle" data-target="adminUserBalancesBody">Show</button>
      </div>
      <div id="adminUserBalancesBody" class="admin-collapsible-body" hidden>
      <form method="post" action="/admin/adjust-all-balances" class="admin-bulk-balance-form" onsubmit="return confirm(`Apply ${this.amount.value} Mushybux to ALL <%= users.length %> users?`);">
        <div>
          <strong>Adjust All User Balances</strong>
          <p class="muted small-note">Use a positive amount to add Mushybux or a negative amount to subtract it.</p>
        </div>
        <input type="number" name="amount" step="1" placeholder="+/- Mushybux each" required>
        <input type="text" name="note" placeholder="Reason (optional)">
        <button type="submit">Adjust All Users</button>
      </form>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>User Details</th>
              <th>Total (Wagered)</th>
              <th>Available</th>
              <th>Adjust Balance</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(u => { %>
              <tr>
                <td>
                  <form method="post" action="/admin/update-user" class="admin-user-edit-form">
                    <input type="hidden" name="user_id" value="<%= u.id %>">
                    <input type="text" name="display_name" value="<%= u.display_name %>" placeholder="Display name" required>
                    <input type="text" name="username" value="<%= u.username %>" placeholder="Username" required>
                    <input type="text" name="password" placeholder="New password (blank = keep)">
                    <select name="role">
                      <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>User</option>
                      <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                    <button type="submit">Save</button>
                  </form>
                </td>
                <td><strong><%= u.balance_display %></strong></td>
                <td><%= u.available_balance %></td>
                <td>
                  <form method="post" action="/admin/adjust-balance" class="admin-balance-adjust-form">
                    <input type="hidden" name="user_id" value="<%= u.id %>">
                    <input type="number" name="amount" step="1" placeholder="+/- Mushybux" required>
                    <input type="text" name="note" placeholder="Reason (optional)">
                    <button type="submit">Adjust</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      </div>
    </section>

    <section class="card admin-card" id="series-odds-recommendations">
      <div class="admin-section-head">
        <h2><%= oddsWeekMode === 'current' ? 'Current Week' : 'Next Week' %> Series Odds Recommendations · Week <%= oddsWeek %></h2>
        <button type="button" class="button-link ghost admin-collapse-toggle" data-target="adminSeriesRecommendationsBody">Show</button>
      </div>
      <div id="adminSeriesRecommendationsBody" class="admin-collapsible-body" hidden>
        <div class="toggle-row admin-odds-week-toggle">
          <a class="button-link <%= oddsWeekMode === 'next' ? 'ghost-active' : 'ghost' %>" href="/admin?odds_week=next#series-odds-recommendations">Next Week</a>
          <a class="button-link <%= oddsWeekMode === 'current' ? 'ghost-active' : 'ghost' %>" href="/admin?odds_week=current#series-odds-recommendations">Current Week Override</a>
        </div>
        <% if (oddsWeekMode === 'current') { %>
          <p class="negative small-note">Current-week changes immediately reprice matching open bets. Use this only to correct lines before betting locks.</p>
        <% } %>
        <p class="muted">
          Model preview using S1/S2 player history and completed S3 games before Week <%= oddsWeek %>.
          Review every editable value, then apply the entire section once.
        </p>
        <form id="bulkSeriesOddsForm" method="post" action="/admin/odds/bulk-series" data-bulk-series-form>
          <input type="hidden" name="week" value="<%= oddsWeek %>">
          <input type="hidden" name="payload" value="">
        </form>

        <% if (seriesOddsRecommendations && seriesOddsRecommendations.error) { %>
          <p class="negative">Unable to build recommendations: <%= seriesOddsRecommendations.error %></p>
        <% } else if (!seriesOddsRecommendations || !seriesOddsRecommendations.recommendations.length) { %>
          <p class="muted">No Week <%= oddsWeek %> series found.</p>
        <% } else { %>
          <div class="odds-model-summary">
            <span><strong><%= Math.round(seriesOddsRecommendations.xgWeight * 100) %>%</strong> xG</span>
            <span><strong><%= seriesOddsRecommendations.teamPriorGames %></strong>-game prior</span>
            <span><strong><%= Math.round(seriesOddsRecommendations.probabilityShrinkage * 100) %>%</strong> probability shrink</span>
            <span><strong>+<%= seriesOddsRecommendations.goalCalibration.toFixed(2) %></strong> goal calibration</span>
            <span><strong><%= seriesOddsRecommendations.sweepCorrectionFactor.toFixed(1) %>x</strong> sweep correction</span>
          </div>

          <div class="odds-recommendation-grid">
            <% seriesOddsRecommendations.recommendations.forEach(rec => { %>
              <article class="odds-recommendation-card">
                <form method="post" action="/admin/odds/series" data-series-odds-form>
                  <input type="hidden" name="week" value="<%= oddsWeek %>">
                  <input type="hidden" name="series_key" value="<%= rec.seriesKey %>">
                <div class="odds-recommendation-head">
                  <div>
                    <span class="pill"><%= rec.divisionId %></span>
                    <h3><%= rec.awayTeamName %> at <%= rec.homeTeamName %></h3>
                  </div>
                  <span class="odds-confidence odds-confidence-<%= rec.confidence.toLowerCase() %>"><%= rec.confidence %> confidence</span>
                </div>

                <div class="odds-projection-strip">
                  <div>
                    <span><%= rec.awayTeamName %></span>
                    <strong><%= (rec.away.seriesWinProbability * 100).toFixed(1) %>%</strong>
                    <small><%= rec.awayExpectedGoalsPerGame.toFixed(2) %> goals/game</small>
                  </div>
                  <div class="odds-projection-vs">VS</div>
                  <div>
                    <span><%= rec.homeTeamName %></span>
                    <strong><%= (rec.home.seriesWinProbability * 100).toFixed(1) %>%</strong>
                    <small><%= rec.homeExpectedGoalsPerGame.toFixed(2) %> goals/game</small>
                  </div>
                </div>

                <div class="table-wrap">
                  <table class="odds-recommendation-table">
                    <thead>
                      <tr>
                        <th>Market</th>
                        <th>Probability</th>
                        <th>Current</th>
                        <th>Suggested</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr>
                        <td><%= rec.awayTeamId %> wins series</td>
                        <td><%= (rec.away.seriesWinProbability * 100).toFixed(1) %>%</td>
                        <td><%= rec.awayCurrent.seriesWinOdds.toFixed(1) %>x</td>
                        <td><input type="hidden" name="market_key" value="<%= rec.seriesKey %>|series_win|<%= rec.awayTeamId %>"><input type="number" name="multiplier" min="0.1" step="0.1" value="<%= (rec.awayCurrent.hasSeriesWin ? rec.awayCurrent.seriesWinOdds : rec.away.seriesWinOdds).toFixed(1) %>"></td>
                      </tr>
                      <tr>
                        <td><%= rec.awayTeamId %> wins 2–1</td>
                        <td><%= (rec.away.exact21Probability * 100).toFixed(1) %>%</td>
                        <td><%= rec.awayCurrent.exact21Odds.toFixed(1) %>x</td>
                        <td><input type="hidden" name="market_key" value="<%= rec.seriesKey %>|exact_2_1|<%= rec.awayTeamId %>"><input type="number" name="multiplier" min="0.1" step="0.1" value="<%= (rec.awayCurrent.hasExact21 ? rec.awayCurrent.exact21Odds : rec.away.exact21Odds).toFixed(1) %>"></td>
                      </tr>
                      <tr>
                        <td><%= rec.awayTeamId %> sweeps 3–0</td>
                        <td><%= (rec.away.sweepProbability * 100).toFixed(1) %>%</td>
                        <td><%= rec.awayCurrent.sweepOdds.toFixed(1) %>x</td>
                        <td><input type="hidden" name="market_key" value="<%= rec.seriesKey %>|sweep_3_0|<%= rec.awayTeamId %>"><input type="number" name="multiplier" min="0.1" step="0.1" value="<%= (rec.awayCurrent.hasSweep ? rec.awayCurrent.sweepOdds : rec.away.sweepOdds).toFixed(1) %>"></td>
                      </tr>
                      <tr>
                        <td><%= rec.homeTeamId %> wins series</td>
                        <td><%= (rec.home.seriesWinProbability * 100).toFixed(1) %>%</td>
                        <td><%= rec.homeCurrent.seriesWinOdds.toFixed(1) %>x</td>
                        <td><input type="hidden" name="market_key" value="<%= rec.seriesKey %>|series_win|<%= rec.homeTeamId %>"><input type="number" name="multiplier" min="0.1" step="0.1" value="<%= (rec.homeCurrent.hasSeriesWin ? rec.homeCurrent.seriesWinOdds : rec.home.seriesWinOdds).toFixed(1) %>"></td>
                      </tr>
                      <tr>
                        <td><%= rec.homeTeamId %> wins 2–1</td>
                        <td><%= (rec.home.exact21Probability * 100).toFixed(1) %>%</td>
                        <td><%= rec.homeCurrent.exact21Odds.toFixed(1) %>x</td>
                        <td><input type="hidden" name="market_key" value="<%= rec.seriesKey %>|exact_2_1|<%= rec.homeTeamId %>"><input type="number" name="multiplier" min="0.1" step="0.1" value="<%= (rec.homeCurrent.hasExact21 ? rec.homeCurrent.exact21Odds : rec.home.exact21Odds).toFixed(1) %>"></td>
                      </tr>
                      <tr>
                        <td><%= rec.homeTeamId %> sweeps 3–0</td>
                        <td><%= (rec.home.sweepProbability * 100).toFixed(1) %>%</td>
                        <td><%= rec.homeCurrent.sweepOdds.toFixed(1) %>x</td>
                        <td><input type="hidden" name="market_key" value="<%= rec.seriesKey %>|sweep_3_0|<%= rec.homeTeamId %>"><input type="number" name="multiplier" min="0.1" step="0.1" value="<%= (rec.homeCurrent.hasSweep ? rec.homeCurrent.sweepOdds : rec.home.sweepOdds).toFixed(1) %>"></td>
                      </tr>
                      <tr class="odds-total-row">
                        <td>Series goal total</td>
                        <td>Projected <%= rec.projectedSeriesGoals.toFixed(1) %></td>
                        <td><%= Number(rec.currentGoalLine).toFixed(1) %></td>
                        <td><input type="number" name="goal_total_line" min="0.5" step="0.5" value="<%= Number(rec.hasSavedGoalLine ? rec.currentGoalLine : rec.recommendedGoalLine).toFixed(1) %>"><input type="hidden" name="goal_total_boost" value="<%= rec.goalTotalBoost %>"></td>
                      </tr>
                    </tbody>
                  </table>
                </div>

                <p class="muted odds-evidence">
                  Historical roster coverage:
                  <strong><%= rec.awayTeamId %> <%= (rec.evidence.awayHistoryCoverage * 100).toFixed(0) %>%</strong>,
                  <strong><%= rec.homeTeamId %> <%= (rec.evidence.homeHistoryCoverage * 100).toFixed(0) %>%</strong>
                  · S3 games included: <%= rec.evidence.awayCurrentGames %>/<%= rec.evidence.homeCurrentGames %>
                </p>
                </form>
              </article>
            <% }) %>
          </div>
          <div class="admin-action-row bulk-odds-submit">
            <button type="submit" form="bulkSeriesOddsForm">Apply All Displayed Series Odds</button>
          </div>
        <% } %>
      </div>
    </section>

    <% if (false) { %>
    <section class="card admin-card" id="following-week-odds">
      <div class="admin-section-head">
        <h2>Following Week Odds Prep · Week <%= followingWeek %></h2>
        <button type="button" class="button-link ghost admin-collapse-toggle" data-target="adminFollowingWeekOddsBody">Show</button>
      </div>
      <div id="adminFollowingWeekOddsBody" class="admin-collapsible-body" hidden>
      <p class="muted">
        These settings apply to Week <%= followingWeek %> only. Users are currently betting on Week <%= nextWeek %>, so these edits stay hidden until that week becomes the open betting week.
      </p>

      <h3>Series Odds</h3>
      <% if (!followingWeekSeriesBoard.length) { %>
        <p class="muted">No Week <%= followingWeek %> series found.</p>
      <% } %>
      <div class="admin-odds-grid">
        <% followingWeekSeriesBoard.forEach(s => { %>
          <form method="post" action="/admin/odds/series" class="admin-odds-card">
            <input type="hidden" name="week" value="<%= followingWeek %>">
            <input type="hidden" name="series_key" value="<%= s.series_key %>">
            <div class="series-head compact-series-head">
              <div>
                <span class="pill"><%= s.division_name %></span>
                <h3><%= s.away_team_name %> at <%= s.home_team_name %></h3>
              </div>
            </div>
            <div class="admin-odds-market-grid">
              <% s.markets.forEach(m => { %>
                <label>
                  <span><%= m.label.replace(s.away_team_name, s.away_team_name).replace(s.home_team_name, s.home_team_name) %></span>
                  <input type="hidden" name="market_key" value="<%= m.market_key %>">
                  <input type="number" name="multiplier" min="0.1" step="0.1" value="<%= m.multiplier %>">
                </label>
              <% }) %>
              <label>
                O/U line
                <input type="number" name="goal_total_line" min="0.5" step="0.5" value="<%= s.goalTotal.line %>">
              </label>
              <label>
                O/U boost
                <input type="number" name="goal_total_boost" min="1" step="0.1" value="<%= s.goalTotal.boost %>">
              </label>
            </div>
            <button type="submit">Save Series Odds</button>
          </form>
        <% }) %>
      </div>

      <h3>Prop Odds</h3>
      <% followingWeekPropBoards.forEach(div => { %>
        <article class="admin-prop-division">
          <h3><%= div.division_name %></h3>
          <div class="admin-prop-grid">
            <% div.categories.forEach(prop => { %>
              <div class="admin-odds-card">
                <form method="post" action="/admin/odds/prop-default" class="admin-prop-default-form">
                  <input type="hidden" name="week" value="<%= followingWeek %>">
                  <input type="hidden" name="division_id" value="<%= div.division_id %>">
                  <input type="hidden" name="category" value="<%= prop.category %>">
                  <h4><%= prop.title %> Defaults</h4>
                  <% if (prop.quantity_options.length) { %>
                    <div class="admin-prop-quantity-grid">
                      <% prop.quantity_options.forEach(q => { %>
                        <label>
                          <%= q.label %>
                          <input type="number" name="quantity_<%= q.quantity %>" min="0.1" step="0.1" value="<%= q.multiplier %>">
                        </label>
                      <% }) %>
                    </div>
                  <% } else { %>
                    <label>
                      Default odds for all players
                      <input type="number" name="multiplier" min="0.1" step="0.1" value="<%= prop.multiplier %>">
                    </label>
                  <% } %>
                  <button type="submit">Save Defaults</button>
                </form>

                <form method="post" action="/admin/odds/player-override" class="admin-player-override-form">
                  <input type="hidden" name="week" value="<%= followingWeek %>">
                  <input type="hidden" name="division_id" value="<%= div.division_id %>">
                  <input type="hidden" name="category" value="<%= prop.category %>">
                  <h4>Individual Override</h4>
                  <label>
                    Player
                    <select name="player_key" required>
                      <option value="">Select player</option>
                      <% prop.players.forEach(player => { %>
                        <% if (prop.quantity_options.length) { %>
                          <option value="<%= player.player_key %>"><%= player.display_name %> · current <%= prop.quantity_options.map(q => `${q.quantity}:${(player.prop_quantity_multipliers && player.prop_quantity_multipliers[q.quantity]) || q.multiplier}x`).join(' / ') %></option>
                        <% } else { %>
                          <option value="<%= player.player_key %>"><%= player.display_name %> · current <%= player.prop_multiplier || prop.multiplier %>x</option>
                        <% } %>
                      <% }) %>
                    </select>
                  </label>
                  <% if (prop.quantity_options.length) { %>
                    <div class="admin-prop-quantity-grid">
                      <% prop.quantity_options.forEach(q => { %>
                        <label>
                          <%= q.label %> custom odds
                          <input type="number" name="quantity_<%= q.quantity %>" min="0.1" step="0.1" placeholder="default <%= q.multiplier %>">
                        </label>
                      <% }) %>
                    </div>
                    <p class="muted small-note">Leave a quantity blank to keep its current/default odds.</p>
                  <% } else { %>
                    <label>
                      Custom odds
                      <input type="number" name="multiplier" min="0.1" step="0.1" placeholder="ex: 2">
                    </label>
                  <% } %>
                  <div class="admin-action-row">
                    <button type="submit">Save Override</button>
                    <button type="submit" name="clear" value="1" class="button-link ghost">Clear Override</button>
                  </div>
                </form>
              </div>
            <% }) %>
          </div>
        </article>
      <% }) %>
      </div>
    </section>
    <% } %>

    <section class="card admin-card" id="leader-prop-recommendations">
      <div class="admin-section-head">
        <h2>Top Scorer / Top Goalie Recommendations · Week <%= oddsWeek %></h2>
        <button type="button" class="button-link ghost admin-collapse-toggle" data-target="adminLeaderPropBody">Show</button>
      </div>
      <div id="adminLeaderPropBody" class="admin-collapsible-body" hidden>
        <p class="muted">Player-specific odds based on historical performance and completed S3 games. D2 uses the faster two-game prior.</p>
        <form id="bulkLeaderPropsForm" method="post" action="/admin/odds/bulk-leader-props" data-bulk-leader-form>
          <input type="hidden" name="week" value="<%= oddsWeek %>">
          <input type="hidden" name="payload" value="">
        </form>
        <% if (leaderPropRecommendations.length && leaderPropRecommendations[0].error) { %>
          <p class="negative"><%= leaderPropRecommendations[0].error %></p>
        <% } else { %>
          <% leaderPropRecommendations.forEach(report => { %>
            <h3><%= report.divisionId %></h3>
            <div class="admin-odds-grid leader-prop-grid">
              <% [['top_scorer', 'Top Scorer', report.topScorer], ['top_goalie', 'Top Goalie', report.topGoalie]].forEach(([category, title, players]) => { %>
                <article class="admin-odds-card">
                  <h3><%= title %></h3>
                  <div class="table-wrap">
                    <table>
                      <thead><tr><th>Player</th><th>Model</th><th>Probability</th><th>Odds</th><th></th></tr></thead>
                      <tbody>
                        <% players.forEach(player => { %>
                          <tr>
                            <td><%= player.playerName %> <small class="muted"><%= player.teamId %></small></td>
                            <td><%= category === 'top_scorer' ? `${player.projectedPpg.toFixed(2)} PPG` : `${(player.projectedSavePct * 100).toFixed(1)} SV%` %></td>
                            <td><%= (player.probability * 100).toFixed(1) %>%</td>
                            <td>
                              <form id="leader-<%= report.divisionId %>-<%= category %>-<%= player.playerKey.replace(/[^a-zA-Z0-9]/g, '-') %>" method="post" action="/admin/odds/player-override" data-leader-odds-form>
                                <input type="hidden" name="week" value="<%= oddsWeek %>">
                                <input type="hidden" name="division_id" value="<%= report.divisionId %>">
                                <input type="hidden" name="category" value="<%= category %>">
                                <input type="hidden" name="player_key" value="<%= player.playerKey %>">
                                <input type="number" name="multiplier" min="1.1" step="0.1" value="<%= player.currentOdds %>">
                              </form>
                            </td>
                            <td></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                </article>
              <% }) %>
            </div>
          <% }) %>
          <div class="admin-action-row bulk-odds-submit">
            <button type="submit" form="bulkLeaderPropsForm">Apply All Displayed Top Scorer / Goalie Odds</button>
          </div>
        <% } %>
      </div>
    </section>

    <section class="card admin-card" id="prop-odds-recommendations">
      <div class="admin-section-head">
        <h2><%= oddsWeekMode === 'current' ? 'Current Week' : 'Next Week' %> Player Prop Recommendations · Week <%= oddsWeek %></h2>
        <button type="button" class="button-link ghost admin-collapse-toggle" data-target="adminPropRecommendationsBody">Show</button>
      </div>
      <div id="adminPropRecommendationsBody" class="admin-collapsible-body" hidden>
        <p class="muted">Apply all automatic recommendations, then inspect review-only players and manually adjust any line or payout that looks wrong.</p>
        <form id="bulkPlayerPropsForm" method="post" action="/admin/odds/bulk-player-props" data-bulk-player-props-form>
          <input type="hidden" name="week" value="<%= oddsWeek %>">
          <input type="hidden" name="payload" value="">
        </form>
        <label class="admin-prop-search">
          Filter props
          <input type="search" id="adminPropSearch" placeholder="Player, team, matchup, D1/D2, review...">
        </label>

        <% if (propOddsRecommendations.length && propOddsRecommendations[0].error) { %>
          <p class="negative"><%= propOddsRecommendations[0].error %></p>
        <% } else if (!propOddsRecommendations.length) { %>
          <p class="muted">No player prop recommendations found for Week <%= oddsWeek %>.</p>
        <% } else { %>
          <div class="admin-odds-grid">
            <% propOddsRecommendations.forEach(market => { %>
              <form method="post" action="/admin/odds/series-prop" class="admin-odds-card" data-player-prop-form data-prop-search="<%= `${market.playerName} ${market.playerTeamId} ${market.opponentTeamId} ${market.matchupLabel} ${market.divisionId} ${market.category} ${market.eligibility}`.toLowerCase() %>">
                <input type="hidden" name="week" value="<%= oddsWeek %>">
                <input type="hidden" name="market_key" value="<%= market.marketKey %>">
                <input type="hidden" name="series_key" value="<%= market.seriesKey %>">
                <input type="hidden" name="division_id" value="<%= market.divisionId %>">
                <input type="hidden" name="category" value="<%= market.category %>">
                <input type="hidden" name="player_key" value="<%= market.playerKey %>">
                <input type="hidden" name="player_name" value="<%= market.playerName %>">
                <input type="hidden" name="player_team_id" value="<%= market.playerTeamId %>">
                <input type="hidden" name="opponent_team_id" value="<%= market.opponentTeamId %>">
                <input type="hidden" name="eligibility" value="<%= market.eligibility %>">
                <div class="series-head compact-series-head">
                  <div>
                    <span class="pill"><%= market.divisionId %> · <%= market.category === 'player_goals' ? 'Skater' : 'Goalie' %></span>
                    <h3><%= market.playerName %> · <%= market.matchupLabel %></h3>
                  </div>
                  <span class="odds-confidence <%= market.eligibility === 'automatic' ? 'odds-confidence-high' : 'odds-confidence-low' %>"><%= market.eligibility === 'automatic' ? 'Automatic' : 'Review' %></span>
                </div>
                <label class="settlement-preview-checkbox">
                  <input type="checkbox" name="enabled" value="1" <%= market.enabled ? 'checked' : '' %>>
                  Publish this prop
                </label>
                <div class="odds-model-summary prop-rate-summary">
                  <span>
                    Career <%= market.rateLabel %>:
                    <strong><%= Number(market.careerRate || 0).toFixed(2) %></strong>
                    <small>(<%= Number(market.careerSample || 0) %> games)</small>
                  </span>
                  <span>
                    S3 <%= market.rateLabel %>:
                    <strong><%= market.currentRate == null ? 'No games' : Number(market.currentRate).toFixed(2) %></strong>
                    <% if (market.currentRate != null) { %>
                      <small>(<%= market.currentSample %> games)</small>
                    <% } %>
                  </span>
                </div>
                <div class="admin-prop-quantity-grid">
                  <% market.tiers.forEach(tier => { %>
                    <div class="admin-prop-tier-column">
                      <input type="hidden" name="label_<%= tier.quantity %>" value="<%= tier.label %>">
                      <label>
                        <%= tier.label %> line
                        <input type="number" name="line_<%= tier.quantity %>" min="0.5" step="0.5" value="<%= tier.line %>">
                      </label>
                      <label>
                        <%= tier.label %> payout
                        <input type="number" name="multiplier_<%= tier.quantity %>" min="1.1" step="0.1" value="<%= tier.multiplier %>">
                      </label>
                    </div>
                  <% }) %>
                </div>
              </form>
            <% }) %>
          </div>
          <div class="admin-action-row bulk-odds-submit">
            <button type="submit" form="bulkPlayerPropsForm">Apply All Displayed Player Props</button>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <script>
    (() => {
      const formValues = (form) => {
        const data = new FormData(form);
        const out = {};
        for (const key of new Set(data.keys())) {
          const values = data.getAll(key);
          out[key] = values.length > 1 ? values : values[0];
        }
        return out;
      };

      document.querySelectorAll(
        '[data-series-odds-form], [data-leader-odds-form], [data-player-prop-form]'
      ).forEach(form => form.addEventListener('submit', event => event.preventDefault()));

      const bulkSeriesForm = document.querySelector('[data-bulk-series-form]');
      bulkSeriesForm?.addEventListener('submit', event => {
        const rows = [...document.querySelectorAll('[data-series-odds-form]')].map(formValues);
        if (!rows.length || !confirm(`Apply all displayed Week ${bulkSeriesForm.elements.week.value} series odds?`)) {
          event.preventDefault();
          return;
        }
        bulkSeriesForm.elements.payload.value = JSON.stringify(rows);
      });

      const bulkLeaderForm = document.querySelector('[data-bulk-leader-form]');
      bulkLeaderForm?.addEventListener('submit', event => {
        const rows = [...document.querySelectorAll('[data-leader-odds-form]')].map(formValues);
        if (!rows.length || !confirm(`Apply all displayed Week ${bulkLeaderForm.elements.week.value} leader prop odds?`)) {
          event.preventDefault();
          return;
        }
        bulkLeaderForm.elements.payload.value = JSON.stringify(rows);
      });

      const bulkPlayerPropsForm = document.querySelector('[data-bulk-player-props-form]');
      bulkPlayerPropsForm?.addEventListener('submit', event => {
        const rows = [...document.querySelectorAll('[data-player-prop-form]')].map(form => {
          const values = formValues(form);
          return {
            market_key: values.market_key,
            series_key: values.series_key,
            division_id: values.division_id,
            category: values.category,
            player_key: values.player_key,
            player_name: values.player_name,
            player_team_id: values.player_team_id,
            opponent_team_id: values.opponent_team_id,
            eligibility: values.eligibility,
            enabled: new FormData(form).has('enabled'),
            tiers: [1, 2, 3].map(quantity => ({
              label: values[`label_${quantity}`],
              line: values[`line_${quantity}`],
              multiplier: values[`multiplier_${quantity}`]
            }))
          };
        });
        if (!rows.length || !confirm(`Apply all displayed Week ${bulkPlayerPropsForm.elements.week.value} player props?`)) {
          event.preventDefault();
          return;
        }
        bulkPlayerPropsForm.elements.payload.value = JSON.stringify(rows);
      });

      const propSearch = document.getElementById('adminPropSearch');
      if (propSearch) {
        const cards = [...document.querySelectorAll('#prop-odds-recommendations [data-prop-search]')];
        propSearch.addEventListener('input', () => {
          const query = propSearch.value.trim().toLowerCase();
          cards.forEach(card => {
            card.hidden = Boolean(query) && !card.dataset.propSearch.includes(query);
          });
        });
      }

      document.querySelectorAll('.admin-collapse-toggle').forEach((btn) => {
        const targetId = btn.dataset.target;
        const body = targetId ? document.getElementById(targetId) : null;
        if (!body) return;

        const syncLabel = () => {
          btn.textContent = body.hidden ? 'Show' : 'Hide';
          btn.setAttribute('aria-expanded', body.hidden ? 'false' : 'true');
        };

        btn.setAttribute('aria-controls', targetId);
        syncLabel();

        btn.addEventListener('click', () => {
          body.hidden = !body.hidden;
          syncLabel();
        });
      });
    })();
  </script>

  <script>
    (() => {
      const table = document.getElementById('settlementPreviewTable');
      const sortSelect = document.getElementById('settlementPreviewSort');
      const hideIncomplete = document.getElementById('settlementPreviewHideIncomplete');
      if (!table || !sortSelect || !hideIncomplete) return;

      const tbody = table.querySelector('tbody');
      const rows = Array.from(tbody.querySelectorAll('tr'));

      const num = (row, key) => Number(row.dataset[key] || 0);
      const text = (row, key) => String(row.dataset[key] || '').toLowerCase();
      const cmpText = (a, b, key) => text(a, key).localeCompare(text(b, key));

      const resultRank = (row) => {
        if (row.dataset.ready !== '1') return 2;
        return row.dataset.won === '1' ? 0 : 1;
      };

      const compareRows = (a, b) => {
        switch (sortSelect.value) {
          case 'ready':
            return num(b, 'ready') - num(a, 'ready') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'incomplete':
            return num(a, 'ready') - num(b, 'ready') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'result':
            return resultRank(a) - resultRank(b) || num(b, 'payout') - num(a, 'payout') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'payout_desc':
            return num(b, 'payout') - num(a, 'payout') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'stake_desc':
            return num(b, 'stake') - num(a, 'stake') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'stake_asc':
            return num(a, 'stake') - num(b, 'stake') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'user_asc':
            return cmpText(a, b, 'user') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'bet_asc':
            return cmpText(a, b, 'bet') || num(a, 'originalIndex') - num(b, 'originalIndex');
          case 'original':
          default:
            return num(a, 'originalIndex') - num(b, 'originalIndex');
        }
      };

      const applyPreviewControls = () => {
        const sortedRows = rows.slice().sort(compareRows);
        for (const row of sortedRows) {
          row.hidden = hideIncomplete.checked && row.dataset.ready !== '1';
          tbody.appendChild(row);
        }
      };

      sortSelect.addEventListener('change', applyPreviewControls);
      hideIncomplete.addEventListener('change', applyPreviewControls);
      applyPreviewControls();
    })();
  </script>

</body>
</html>
